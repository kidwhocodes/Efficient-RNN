{
  "output_dir": "checkpoints/neurosuite",
  "defaults": {
    "train_steps": 800,
    "ft_steps": 0,
    "last_only": false,
    "device": "cpu",
    "movement_batches": 32,
    "hidden_size": 256,
    "ng_T": 400,
    "ng_B": 64
  },
  "tasks": [
    {
      "task": "synthetic",
      "train_steps": 600,
      "last_only": true,
      "hidden_size": 128,
      "seeds": [0, 1]
    },
    {
      "task": "synthetic_context",
      "train_steps": 800,
      "last_only": true,
      "hidden_size": 128,
      "seeds": [0, 1]
    },
    {
      "task": "ng:PerceptualDecisionMaking-v0",
      "ng_kwargs": {"timing": {"decision": [300, 700]}},
      "seeds": [0, 1]
    },
    {
      "task": "ng:ContextDecisionMaking-v0",
      "ng_kwargs": {"timing": {"delay": [200, 400]}},
      "seeds": [0, 1]
    },
    {
      "task": "ng:DelayMatchSample-v0",
      "seeds": [0, 1]
    }
  ]
}
